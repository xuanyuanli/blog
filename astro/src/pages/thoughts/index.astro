---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/Navbar';
import { getCollection } from 'astro:content';
import type { Thought } from '@/lib/types';
import { ArrowLeft } from 'lucide-react';

const entries = await getCollection('thoughts');
const thoughts: Thought[] = entries
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((entry) => ({
    slug: entry.data.path || entry.slug,
    title: entry.data.title,
    date: entry.data.date.toISOString().slice(0, 10),
    excerpt: entry.data.excerpt,
    content: entry.body ?? '',
  }));
---

<BaseLayout title="思考碎片 | 轩辕李">
  <main>
    <Navbar client:load />
    <div class="min-h-screen pt-24 pb-16 px-6">
      <div class="max-w-3xl mx-auto">
        <!-- 返回首页 -->
        <a
          href="/"
          class="inline-flex items-center gap-2 text-[var(--text-secondary)] hover:text-white transition-colors mb-12"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <span>返回首页</span>
        </a>

        <h1 class="text-4xl font-bold mb-4">思考碎片</h1>
        <p class="text-[var(--text-secondary)] mb-12">
          不系统的、碎片化的、但真实的想法
        </p>

        <!-- 思考列表 -->
        <div class="space-y-8">
          {thoughts.map((thought) => (
            <a
              href={`/thoughts/${thought.slug}`}
              class="block p-6 rounded-xl border border-white/10 bg-[var(--card-bg)] hover:border-accent-start/50 transition-all duration-300 group"
            >
              <span class="text-xs text-[var(--text-secondary)] mb-2 block">
                {thought.date}
              </span>
              <h2 class="text-xl font-medium mb-2 group-hover:text-gradient transition-all">
                {thought.title}
              </h2>
              <p class="text-sm text-[var(--text-secondary)] line-clamp-3">
                {thought.excerpt}
              </p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
